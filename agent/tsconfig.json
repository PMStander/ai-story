{
  "compilerOptions": {
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "verbatimModuleSyntax": false
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
