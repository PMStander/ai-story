rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Settings subcollection (usage tracking, preferences)
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Projects subcollection
      match /projects/{projectId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // All nested subcollections (chapters, characters, assets, publishing)
        match /{subcollection}/{docId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;

          // Nested under subcollections (e.g., illustrations under chapters)
          match /{nestedCol}/{nestedId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
          }
        }
      }

      // Campaigns subcollection (Ads Manager)
      match /campaigns/{campaignId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Public showcase (opt-in community sharing)
    match /showcase/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
